<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video Surface -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextureView
        android:id="@+id/textureView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Modern Floating Status Bar (Top) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/statusBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- FPS Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FPS"
                    android:textColor="#88FFFFFF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/fpsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#4CAF50"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bitrate Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BITRATE"
                    android:textColor="#88FFFFFF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/bitrateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Resolution Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESOLUTION"
                    android:textColor="#88FFFFFF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/resolutionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- RTT Latency Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RTT"
                    android:textColor="#88FFFFFF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/latencyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#E91E63"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Settings Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/settingsButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_settings"
            android:tint="#FFFFFF" />
    </androidx.cardview.widget.CardView>

    <!-- Modern Connection Panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/settingsPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:elevation="24dp"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="#E6000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="40dp">

            <!-- Icon -->
            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/connection_icon_bg"
                android:layout_marginBottom="24dp" />

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Side Screen"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Turn your tablet into a second display"
                android:textColor="#999999"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Mode toggle: USB / Wireless -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/modeToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/modeUSB"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="USB"
                    android:textColor="@color/mode_toggle_text"
                    app:backgroundTint="@color/mode_toggle_bg"
                    app:strokeColor="#444444"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/modeWireless"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Wireless"
                    android:textColor="@color/mode_toggle_text"
                    app:backgroundTint="@color/mode_toggle_bg"
                    app:strokeColor="#444444"
                    app:strokeWidth="1dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- ============= USB MODE CONTENT ============= -->
            <LinearLayout
                android:id="@+id/usbModeContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Connection Checklist -->
            <LinearLayout
                android:id="@+id/checklistContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/instruction_bg"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connection Checklist"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Developer Mode Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:id="@+id/checkDeveloperMode"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textDeveloperMode"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Developer Mode enabled"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- USB Debugging Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:id="@+id/checkUsbDebugging"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textUsbDebugging"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="USB Debugging enabled"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- USB Connected Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:id="@+id/checkUsbConnected"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textUsbConnected"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="USB cable connected"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Mac Server Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:id="@+id/checkMacServer"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textMacServer"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Mac server running"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Connect Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Connect"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:backgroundTint="#007AFF"
                android:layout_marginBottom="20dp" />

            <!-- Status Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/status_indicator"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ready to connect"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Advanced Settings (collapsed by default) -->
            <LinearLayout
                android:id="@+id/advancedSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#FFFFFF"
                    app:hintTextColor="#AAAAAA"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/hostInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Host"
                        android:text="127.0.0.1"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#FFFFFF"
                    app:hintTextColor="#AAAAAA">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/portInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Port"
                        android:text="54321"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Show Advanced link -->
            <TextView
                android:id="@+id/showAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advanced Settings"
                android:textColor="#007AFF"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="8dp" />

            </LinearLayout>
            <!-- ============= /USB MODE CONTENT ============= -->

            <!-- ============= WIRELESS MODE CONTENT ============= -->
            <LinearLayout
                android:id="@+id/wirelessModeContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- State: Connecting (auto or after scan) -->
                <LinearLayout
                    android:id="@+id/wirelessConnecting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminateTint="#4CAF50"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/connectingLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Connecting…"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/connectingSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#999999"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- State 1: First-time -->
                <LinearLayout
                    android:id="@+id/wirelessFirstTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pair with your Mac"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Open Side Screen on your Mac → switch to the Wireless tab → scan the QR shown"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessScanButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Scan QR Code"
                        android:textSize="16sp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#4ade80"
                        android:textColor="#000000" />
                </LinearLayout>

                <!-- State 3: Connected -->
                <LinearLayout
                    android:id="@+id/wirelessConnected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="● Connected"
                        android:textColor="#4ade80"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/connectedMacName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mac"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/connectedMacIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessDisconnectButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Disconnect"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessForgetButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Forget this Mac"
                        android:textColor="#fca5a5"
                        app:strokeColor="#7f1d1d" />
                </LinearLayout>

                <!-- State: Paired idle (after explicit Disconnect) -->
                <LinearLayout
                    android:id="@+id/wirelessPairedIdle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="○ Disconnected"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/idleMacName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mac"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/idleMacIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessReconnectButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Reconnect"
                        android:textSize="16sp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessIdleForgetButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Forget this Mac"
                        android:textColor="#fca5a5"
                        app:strokeColor="#7f1d1d" />
                </LinearLayout>

                <!-- State 4: Token mismatch / re-pair -->
                <LinearLayout
                    android:id="@+id/wirelessTokenMismatch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/repairTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠ Couldn't connect"
                        android:textColor="#fca5a5"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/repairMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Scan a fresh QR from your Mac to re-pair."
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessRescanButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Scan QR Code"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#4ade80"
                        android:textColor="#000000" />
                </LinearLayout>

                <!-- State 5: Permission denied permanently -->
                <LinearLayout
                    android:id="@+id/wirelessPermDenied"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Camera permission required to scan QR"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="You blocked the permission. Open Settings → Apps → Side Screen → Permissions to allow."
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessOpenSettingsButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Open Settings"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#007AFF" />
                </LinearLayout>

            </LinearLayout>
            <!-- ============= /WIRELESS MODE CONTENT ============= -->

            <!-- Hidden disconnect button reference (needed by code) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/disconnectButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Hidden log text (needed by code) -->
    <TextView
        android:id="@+id/logText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
